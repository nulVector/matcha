{
  "name": "load-tests",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "clean": "rimraf dist .turbo",
    "test:seed-matchmaking": "ts-node src/scripts/seed-matchmaking.ts",
    "test:seed-messaging": "ts-node src/scripts/seed-messaging.ts",
    "test:seed-app": "ts-node src/scripts/seed-app.ts",
    "test:heartbeats": "artillery run src/scenarios/heartbeats.yml",
    "test:messaging": "artillery run src/scenarios/messaging.yml",
    "test:receipts": "artillery run src/scenarios/receipts.yml",

    "test:real-world": "artillery run src/scenarios/real-world.yml"
  },
  "dependencies": {
    "@matcha/prisma": "workspace:*",
    "@matcha/redis": "workspace:*",
    "@paralleldrive/cuid2": "^3.3.0",

{
  "name": "workers",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node ./dist/index.js",
    "dev": "tsc & nodemon ./dist/index.js",
    "clean": "rimraf dist .turbo",
    "queue:clean-dlq": "ts-node src/scripts/cleanDlq.ts",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@matcha/emails": "workspace:*",
    "@matcha/logger": "workspace:*",
    "@matcha/prisma": "workspace:*",
    "@matcha/queue": "workspace:*",
    "@matcha/redis": "workspace:*",
    "@paralleldrive/cuid2": "^3.3.0",
    "bullmq": "^5.70.1",
    "ioredis": "^5.9.2",
    "prom-client": "15.1.3",
    "resend": "^6.12.3",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@matcha/eslint-config": "workspace:*",
    "@matcha/shared": "workspace:*",
    "@matcha/typescript-config": "workspace:*",
    "eslint": "^9.39.1"
  }
}
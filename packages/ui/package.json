    "framer-motion": "12.42.0",
    "lucide-react": "^1.7.0",
    "postcss": "^8.5.8",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.1",
    "react-textarea-autosize": "^8.5.9",

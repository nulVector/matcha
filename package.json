{
  "name": "matcha",
  "private": true,
  "scripts": {
    "build": "dotenv -e .env -- turbo run build",
    "dev": "dotenv -e .env -- turbo run dev",
    "test": "dotenv -e .env -- vitest",
    "clean": "turbo run clean && rimraf node_modules .turbo",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:migrate": "dotenv -e .env -- turbo run db:migrate --filter=@matcha/prisma",
    "db:push": "dotenv -e .env -- turbo run db:push --filter=@matcha/prisma",
    "db:studio": "dotenv -e .env -- turbo run db:studio --filter=@matcha/prisma",
    "db:seed": "dotenv -e .env -- turbo run db:seed --filter=@matcha/prisma",
    "dev:test": "dotenv -e .env.test -- turbo run dev",
    "docker:test:up": "docker-compose -f docker-compose.test.yml up -d",
    "docker:test:down": "docker-compose -f docker-compose.test.yml down -v",
    "db:test:push": "dotenv -e .env.test -- turbo run db:push --filter=@matcha/prisma",
    "db:test:seed": "dotenv -e .env.test -- turbo run db:seed --filter=@matcha/prisma",
    "docker:test:setup": "pnpm docker:test:up && timeout 3 && pnpm db:test:push && pnpm db:test:seed",
    "db:test:studio": "dotenv -e .env.test -- turbo run db:studio --filter=@matcha/prisma",
    "loadtest": "dotenv -e .env.test -- pnpm --filter=load-tests run"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.7.4",
    "rimraf": "^6.1.2",
    "turbo": "^2.6.3",
    "typescript": "5.9.2",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
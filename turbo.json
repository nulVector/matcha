{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**","dist/**","!node_modules/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "db:migrate": {
      "cache": false,
      "interactive": true,
      "env": ["DATABASE_URL"]
    },
    "db:push": {
      "cache": false,
      "interactive": true,
      "env": ["DATABASE_URL"]
    },
    "db:studio": {
      "cache": false,
      "interactive": true,
      "env": ["DATABASE_URL"]
    },
    "db:seed": {
      "cache": false,
      "interactive": true,
      "env": ["DATABASE_URL"]
    },
    "clean": {
      "cache": false
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["*"]
    },
    "dev:test": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["*"]
    },
    "loadtest": {
      "cache": false,
      "interactive": true,
      "env": [
        "DATABASE_URL",
        "JWT_SECRET",
        "REDIS_URL",
        "API_URL"
    ]
    }
  }
}
